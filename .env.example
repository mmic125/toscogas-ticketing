# ─── Database ───────────────────────────────────────────────
DB_NAME=toscogas_ticketing
DB_USER=toscogas
DB_PASSWORD=CHANGE_ME_strong_password_32chars

# ─── MinIO (object storage) ─────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME_strong_minio_password
MINIO_ACCESS_KEY=CHANGE_ME_access_key
MINIO_SECRET_KEY=CHANGE_ME_secret_key_32chars

# ─── App ────────────────────────────────────────────────────
APP_URL=https://ticketing.example.com

# ─── SMTP (per reset password) ───────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASS=CHANGE_ME_smtp_password
SMTP_FROM="Toscogas Ticketing <noreply@example.com>"

# ─── Frontend (Vite build) ──────────────────────────────────
VITE_API_URL=https://ticketing.example.com
